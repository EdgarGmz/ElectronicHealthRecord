<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AppEHR.ViewModels"
             xmlns:converters="clr-namespace:AppEHR.Converters"
             x:Class="AppEHR.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             Title="Iniciar Sesión">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StringToBooleanConverter x:Key="StringToBooleanConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <!-- Background Gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{AppThemeBinding Light={StaticResource GradientStartLight}, Dark={StaticResource GradientStartDark}}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light={StaticResource GradientEndLight}, Dark={StaticResource GradientEndDark}}" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView VerticalOptions="Center" HorizontalOptions="Center">
            <VerticalStackLayout Spacing="20" Padding="20">
                
                <!-- Logo & Header -->
                <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                    <Label Text="🏥" FontSize="64" HorizontalOptions="Center" />
                    <Label Text="EHR System" 
                           FontSize="28" 
                           FontAttributes="Bold" 
                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                           HorizontalOptions="Center" />
                    <Label Text="Asistente de Psicología" 
                           FontSize="14" 
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Glass Card Container -->
                <Border StrokeThickness="1.2"
                        Stroke="{AppThemeBinding Light={StaticResource GlassBorderLight}, Dark={StaticResource GlassBorderDark}}"
                        Background="{AppThemeBinding Light={StaticResource GlassBgLight}, Dark={StaticResource GlassBgDark}}"
                        Padding="24"
                        WidthRequest="340"
                        HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.1" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">
                        
                        <!-- Email Input -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Correo Institucional" 
                                   FontSize="12" 
                                   FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                            <Border StrokeThickness="1" 
                                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                    Background="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry Text="{Binding Email}" 
                                       Placeholder="nombre@institucion.edu.mx" 
                                       Keyboard="Email" 
                                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                                       PlaceholderColor="Gray"
                                       Margin="6,0"
                                       HeightRequest="44"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password Input -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Contraseña" 
                                   FontSize="12" 
                                   FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                            <Border StrokeThickness="1" 
                                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                    Background="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry Text="{Binding Password}" 
                                       Placeholder="••••••••" 
                                       IsPassword="True" 
                                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                                       PlaceholderColor="Gray"
                                       Margin="6,0"
                                       HeightRequest="44"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Remember Me Option -->
                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center" Margin="2,0,0,0">
                            <CheckBox IsChecked="{Binding RememberMe}" Color="{StaticResource BrandPrimary}" />
                            <Label Text="Mantener sesión abierta" 
                                   VerticalOptions="Center" 
                                   FontSize="13" 
                                   TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" />
                        </HorizontalStackLayout>

                        <!-- Error Message -->
                        <Label Text="{Binding ErrorMessage}" 
                               TextColor="{StaticResource BrandError}" 
                               FontSize="12" 
                               HorizontalOptions="Center" 
                               HorizontalTextAlignment="Center"
                               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBooleanConverter}}" />

                        <!-- Login Button -->
                        <Button Text="Iniciar Sesión" 
                                Command="{Binding LoginCommand}" 
                                BackgroundColor="{StaticResource BrandPrimary}" 
                                TextColor="White" 
                                CornerRadius="12" 
                                FontAttributes="Bold"
                                HeightRequest="48"
                                Margin="0,8,0,0"/>

                        <!-- Loading Indicator -->
                        <ActivityIndicator IsRunning="{Binding IsBusy}" 
                                           IsVisible="{Binding IsBusy}" 
                                           Color="{StaticResource BrandPrimary}" 
                                           HorizontalOptions="Center" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
