<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AppEHR.ViewModels"
             xmlns:models="clr-namespace:AppEHR.Models"
             xmlns:converters="clr-namespace:AppEHR.Converters"
             x:Class="AppEHR.Views.DashboardPage"
             x:Name="ThisPage"
             Title="Mi Agenda">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StringToBooleanConverter x:Key="StringToBooleanConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <!-- Background Gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{AppThemeBinding Light={StaticResource GradientStartLight}, Dark={StaticResource GradientStartDark}}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light={StaticResource GradientEndLight}, Dark={StaticResource GradientEndDark}}" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Padding="16,10" RowSpacing="12">
            
            <!-- Header Row -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="Hola," FontSize="14" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                    <Label Text="{Binding PsychologistName}" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                </VerticalStackLayout>
                <Button Grid.Column="1" 
                        Text="Salir" 
                        Command="{Binding LogoutCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource BrandError}"
                        FontAttributes="Bold"
                        VerticalOptions="Center" />
            </Grid>

            <!-- Statistics & Grounding Phrase (Glass Card) -->
            <Border Grid.Row="1"
                    StrokeThickness="1.2"
                    Stroke="{AppThemeBinding Light={StaticResource GlassBorderLight}, Dark={StaticResource GlassBorderDark}}"
                    Background="{AppThemeBinding Light={StaticResource GlassBgLight}, Dark={StaticResource GlassBgDark}}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.05" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="10">
                    <!-- Grounding Phrase -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="🧠" FontSize="20" VerticalOptions="Center" />
                        <Label Grid.Column="1" 
                               Text="{Binding Stats.GroundingPhrase}" 
                               FontSize="12" 
                               FontAttributes="Italic"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" 
                               VerticalOptions="Center" />
                    </Grid>
                    
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}" />

                    <!-- Workload Progress -->
                    <VerticalStackLayout Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Carga de Trabajo Semanal" FontSize="11" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                            <Label Grid.Column="1" Text="{Binding Stats.HoursThisWeek, StringFormat='{0}h / 25h'}" FontSize="11" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource PrimaryDark}}" />
                        </Grid>
                        <ProgressBar Progress="{Binding Stats.WorkloadPercentage, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=ProgressBar}" 
                                     ProgressColor="{StaticResource BrandPrimary}"
                                     HeightRequest="6"/>
                    </VerticalStackLayout>

                    <!-- Monthly Metrics Summary -->
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="4">
                        <!-- Total -->
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                            <Label Text="{Binding Stats.TotalAppointments}" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                            <Label Text="Mes" FontSize="9" HorizontalOptions="Center" TextColor="Gray" />
                        </VerticalStackLayout>
                        <!-- Completed -->
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                            <Label Text="{Binding Stats.CompletedAppointments}" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource BrandSuccess}" />
                            <Label Text="Listas" FontSize="9" HorizontalOptions="Center" TextColor="Gray" />
                        </VerticalStackLayout>
                        <!-- Cancelled -->
                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                            <Label Text="{Binding Stats.CancelledAppointments}" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource BrandError}" />
                            <Label Text="Canc." FontSize="9" HorizontalOptions="Center" TextColor="Gray" />
                        </VerticalStackLayout>
                        <!-- Patients -->
                        <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center">
                            <Label Text="{Binding Stats.TotalPatients}" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                            <Label Text="Pacientes" FontSize="9" HorizontalOptions="Center" TextColor="Gray" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Navigation Mode Selector (Tabs) -->
            <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="8" HeightRequest="40">
                <Button Grid.Column="0" 
                        Text="Hoy"
                        Command="{Binding ChangeViewModeCommand}" 
                        CommandParameter="today"
                        TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource GlassBgLight}, Dark={StaticResource GlassBgDark}}"
                        BorderWidth="1"
                        BorderColor="{AppThemeBinding Light={StaticResource GlassBorderLight}, Dark={StaticResource GlassBorderDark}}"
                        CornerRadius="10"
                        FontSize="12">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding SelectedViewMode}" Value="today">
                            <Setter Property="BackgroundColor" Value="{StaticResource BrandPrimary}" />
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Grid.Column="1" 
                        Text="Semana" 
                        Command="{Binding ChangeViewModeCommand}" 
                        CommandParameter="week"
                        TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource GlassBgLight}, Dark={StaticResource GlassBgDark}}"
                        BorderWidth="1"
                        BorderColor="{AppThemeBinding Light={StaticResource GlassBorderLight}, Dark={StaticResource GlassBorderDark}}"
                        CornerRadius="10"
                        FontSize="12">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding SelectedViewMode}" Value="week">
                            <Setter Property="BackgroundColor" Value="{StaticResource BrandPrimary}" />
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Grid.Column="2" 
                        Text="Mes" 
                        Command="{Binding ChangeViewModeCommand}" 
                        CommandParameter="month"
                        TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource GlassBgLight}, Dark={StaticResource GlassBgDark}}"
                        BorderWidth="1"
                        BorderColor="{AppThemeBinding Light={StaticResource GlassBorderLight}, Dark={StaticResource GlassBorderDark}}"
                        CornerRadius="10"
                        FontSize="12">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding SelectedViewMode}" Value="month">
                            <Setter Property="BackgroundColor" Value="{StaticResource BrandPrimary}" />
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>

            <!-- Agenda Itinerary List -->
            <RefreshView Grid.Row="3" Command="{Binding LoadDataCommand}" IsRefreshing="{Binding IsBusy}">
                <CollectionView ItemsSource="{Binding Appointments}" SelectionMode="None">
                    
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Spacing="8" VerticalOptions="Center" HorizontalOptions="Center" Padding="40">
                            <Label Text="📅" FontSize="48" HorizontalOptions="Center" />
                            <Label Text="No hay citas registradas" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" TextColor="Gray" />
                            <Label Text="No tienes citas asignadas en el rango seleccionado." FontSize="12" HorizontalOptions="Center" HorizontalTextAlignment="Center" TextColor="Gray" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Appointment">
                            <Grid Padding="0,4,0,8">
                                <Border StrokeThickness="1"
                                        Stroke="{AppThemeBinding Light={StaticResource GlassBorderLight}, Dark={StaticResource GlassBorderDark}}"
                                        Background="{AppThemeBinding Light={StaticResource GlassBgLight}, Dark={StaticResource GlassBgDark}}"
                                        Padding="14">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14" />
                                    </Border.StrokeShape>

                                    <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="6">
                                        <!-- Time & Duration -->
                                        <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6" VerticalOptions="Center">
                                            <Label Text="🕒" FontSize="14" />
                                            <Label Text="{Binding FormattedTime}" FontAttributes="Bold" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                                            <Label Text="{Binding DurationMinutes, StringFormat='({0} min)'}" FontSize="12" TextColor="Gray" VerticalOptions="Center" />
                                        </HorizontalStackLayout>

                                        <!-- Status Tag -->
                                        <Border Grid.Row="0" Grid.Column="1" Padding="8,3" BackgroundColor="{Binding StatusColor}">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="6" />
                                            </Border.StrokeShape>
                                            <Label Text="{Binding LocalizedStatus}" FontSize="10" FontAttributes="Bold" TextColor="White" />
                                        </Border>

                                        <!-- Patient Info -->
                                        <VerticalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="2" Margin="0,4,0,4">
                                            <Label Text="{Binding Patient.User.FullName}" FontSize="15" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                                <Label Grid.Column="0" Text="🎓" FontSize="11" IsVisible="{Binding Patient.Career, Converter={StaticResource StringToBooleanConverter}}" />
                                                <Label Grid.Column="1" Text="{Binding Patient.Career.Name}" FontSize="11" TextColor="Gray" LineBreakMode="NoWrap" />
                                            </Grid>
                                        </VerticalStackLayout>

                                        <!-- Contact Links & Type -->
                                        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Margin="0,2,0,0">
                                            <!-- Type Tag -->
                                            <Border Grid.Column="0" Padding="8,4" BackgroundColor="Transparent" Stroke="Gray" StrokeThickness="0.8">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="6" />
                                                </Border.StrokeShape>
                                                <Label Text="{Binding LocalizedType}" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                                            </Border>

                                            <!-- Spacing -->
                                            <BoxView Grid.Column="1" Color="Transparent" />

                                            <!-- Contact Buttons -->
                                            <HorizontalStackLayout Grid.Column="2" Spacing="8">
                                                <!-- Email Button -->
                                                <Button Text="✉️ Correo" 
                                                        Command="{Binding BindingContext.EmailCommand, Source={x:Reference ThisPage}}" 
                                                        CommandParameter="{Binding Patient.User.Email}"
                                                        BackgroundColor="Transparent"
                                                        TextColor="{StaticResource BrandPrimary}"
                                                        FontAttributes="Bold"
                                                        FontSize="11"
                                                        Padding="4,2"
                                                        HeightRequest="30" />
                                                
                                                <!-- WhatsApp Button -->
                                                <Button Text="💬 WhatsApp" 
                                                        Command="{Binding BindingContext.WhatsAppCommand, Source={x:Reference ThisPage}}" 
                                                        CommandParameter="{Binding Patient.User.Phone}"
                                                        BackgroundColor="Transparent"
                                                        TextColor="#25D366"
                                                        FontAttributes="Bold"
                                                        FontSize="11"
                                                        Padding="4,2"
                                                        HeightRequest="30" />
                                            </HorizontalStackLayout>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>

            <!-- Bottom Floating-Like Agendar Button -->
            <Button Grid.Row="4" 
                    Text="➕ Agendar Cita Rápida" 
                    Command="{Binding NavigateToQuickAppointmentCommand}"
                    BackgroundColor="{StaticResource BrandPrimary}"
                    TextColor="White"
                    CornerRadius="16"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    Shadow="{Shadow Brush=Black, Offset='0,4', Radius=8, Opacity=0.15}" />
        </Grid>
    </Grid>

</ContentPage>
