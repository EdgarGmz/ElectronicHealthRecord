---
// Kiosko/src/components/PsychologySection.astro
const psychologyTips = [
    {
        title: "Apoyo Emocional",
        description: "Herramientas para gestionar tus emociones y fortalecer tu resiliencia.",
        icon: "🧠",
        details: "Gestión del duelo, Inteligencia emocional, Resolución de conflictos, Regulación afectiva",
        fullInfo: "El apoyo emocional brinda herramientas prácticas para manejar situaciones de crisis. Aprender a identificar lo que sientes es vital para una salud mental sólida."
    },
    {
        title: "Manejo del Estrés",
        description: "Técnicas de relajación para reducir la ansiedad académica.",
        icon: "🌊",
        details: "Mindfulness, Técnicas de respiración, Relajación muscular, Gestión de ansiedad",
        fullInfo: "El estrés afecta tu rendimiento. Te enseñamos estrategias probadas para calmar tu sistema nervioso y recuperar el control en momentos de alta presión."
    },
    {
        title: "Habilidades de Estudio",
        description: "Estrategias de organización y métodos de aprendizaje efectivos.",
        icon: "📚",
        details: "Métodos de memorización, Gestión del tiempo, Concentración, Hábitos de lectura",
        fullInfo: "Optimiza tu aprendizaje con técnicas que mejoran la retención de información y organizan tu tiempo para evitar el agotamiento académico."
    },
    {
        title: "Relaciones Saludables",
        description: "Construye vínculos positivos y establece límites sanos.",
        icon: "🤝",
        details: "Comunicación asertiva, Empatía, Límites personales, Vínculos afectivos",
        fullInfo: "Las relaciones sanas se basan en el respeto. Aprender a decir 'no' y expresar tus necesidades mejora tu bienestar social y tu autoestima."
    },
    {
        title: "Prevención de Adicciones",
        description: "Orientación sobre riesgos y factores de protección.",
        icon: "🚫",
        details: "Factores de riesgo, Redes de apoyo, Estilos de vida sanos, Toma de decisiones",
        fullInfo: "Identificar situaciones de riesgo y contar con una red de apoyo es vital para mantener una vida equilibrada y libre de dependencias."
    },
    {
        title: "Autoestima y Autoconcepto",
        description: "Trabaja en tu confianza y seguridad personal.",
        icon: "✨",
        details: "Aceptación personal, Fortalezas individuales, Autocuidado, Imagen corporal",
        fullInfo: "Trabajamos en reconocer tus logros, fomentando un diálogo interno positivo que te permita crecer con seguridad y confianza."
    },
    {
        title: "Orientación de Carrera",
        description: "Acompañamiento en la toma de decisiones profesionales.",
        icon: "🚀",
        details: "Perfil profesional, Mercado laboral, Proyecto de vida, Intereses vocacionales",
        fullInfo: "Te ayudamos a alinear tus pasiones con las oportunidades reales, construyendo un proyecto de vida con propósito y metas claras."
    }
];
---

<section id="psychology-section" class="page-section">
    <h2 class="section-title">Apoyo Psicopedagógico</h2>
    
    <div class="options-container">
        {psychologyTips.map((tip) => (
            <div class="option-card interactive-psych-card" 
                 data-title={tip.title} 
                 data-icon={tip.icon} 
                 data-info={tip.fullInfo} 
                 data-list={tip.details}>
                <div class="card-icon animated-icon-soft">{tip.icon}</div>
                <h3>{tip.title}</h3>
                <p>{tip.description}</p>
                <span class="click-hint-psych">Toca para saber más</span>
            </div>
        ))}
    </div>

    <!-- Modal Blanco Estable -->
    <div id="psych-modal-fixed" class="custom-modal-overlay">
        <div class="custom-modal-content">
            <button class="custom-close-btn" id="close-psych-modal">&times;</button>
            <div class="modal-inner-header">
                <div class="modal-big-icon pop-in-soft" id="psych-modal-icon"></div>
                <h2 id="psych-modal-title"></h2>
            </div>
            <div class="modal-inner-body">
                <p id="psych-modal-desc"></p>
                <div class="modal-inner-highlights">
                    <h4>Información Clave</h4>
                    <ul id="psych-modal-list"></ul>
                </div>
            </div>
            <button class="modal-inner-close-action" id="btn-psych-close">Entendido</button>
        </div>
    </div>
</section>

<script is:inline>
    (function() {
        const initPsychModal = () => {
            const modal = document.getElementById('psych-modal-fixed');
            const cards = document.querySelectorAll('.interactive-psych-card');
            const closeX = document.getElementById('close-psych-modal');
            const closeBtn = document.getElementById('btn-psych-close');

            if (!modal) return;

            const open = (data) => {
                const iconEl = document.getElementById('psych-modal-icon');
                document.getElementById('psych-modal-title').textContent = data.title;
                document.getElementById('psych-modal-desc').textContent = data.info;
                iconEl.textContent = data.icon;
                
                const list = document.getElementById('psych-modal-list');
                list.innerHTML = data.list.split(',').map(i => `<li><span>✓</span> ${i.trim()}</li>`).join('');

                modal.classList.add('is-visible');
                
                // Reiniciar animación pop-in sutil
                iconEl.style.animation = 'none';
                iconEl.offsetHeight;
                iconEl.style.animation = null;

                document.body.style.overflow = 'hidden';
            };

            const close = () => {
                modal.classList.remove('is-visible');
                document.body.style.overflow = '';
            };

            cards.forEach(card => {
                card.addEventListener('click', () => open(card.dataset));
            });

            closeX?.addEventListener('click', close);
            closeBtn?.addEventListener('click', close);
            modal.addEventListener('click', (e) => {
                if (e.target === modal) close();
            });
        };

        initPsychModal();
        document.addEventListener('astro:after-swap', initPsychModal);
    })();
</script>

<style>
    .page-section {
        width: 100%;
        max-width: 1200px;
        padding: 4rem 2rem;
        box-sizing: border-box;
        text-align: center;
        border-bottom: 1px solid var(--navbar-border);
        background-color: var(--bg-color);
    }

    .section-title {
        font-size: 2.5rem;
        margin-bottom: 3rem;
        color: var(--heading-color);
        font-family: 'Playfair Display', serif;
    }

    .options-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 3rem;
        text-align: left;
    }

    .option-card {
        padding: 2rem;
        transition: all 0.3s ease;
        background-color: var(--card-bg);
        border-radius: 12px;
        cursor: pointer;
        border: 1px solid var(--navbar-border);
        display: flex;
        flex-direction: column;
        position: relative;
    }

    .option-card:hover {
        background-color: rgba(162, 217, 206, 0.1);
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    }

    /* --- ANIMACIÓN SOFT DE EMOJIS (No sale de su órbita) --- */
    .animated-icon-soft {
        font-size: 2.5rem;
        margin-bottom: 1rem;
        display: inline-block;
        transform-origin: center;
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .option-card:hover .animated-icon-soft {
        transform: scale(1.15) rotate(-5deg);
    }

    .option-card h3 { font-size: 1.5rem; margin-bottom: 0.5rem; color: var(--heading-color); font-family: 'Playfair Display', serif; }
    .option-card p { font-size: 1rem; line-height: 1.6; color: var(--body-text-color); margin-bottom: 1rem; }
    
    .click-hint-psych { font-size: 0.8rem; color: #A2D9CE; font-weight: bold; text-transform: uppercase; margin-top: auto; }

    /* --- MODAL --- */
    .custom-modal-overlay {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.6);
        display: flex; align-items: center; justify-content: center;
        z-index: 9999; opacity: 0; visibility: hidden;
        transition: all 0.3s ease;
        backdrop-filter: blur(5px);
    }

    .custom-modal-overlay.is-visible { opacity: 1; visibility: visible; }

    .custom-modal-content {
        background: var(--card-bg);
        width: 90%; max-width: 500px;
        padding: 3rem; border-radius: 15px;
        position: relative; box-shadow: 0 25px 50px rgba(0,0,0,0.3);
        border: 1px solid var(--navbar-border);
        transform: translateY(20px);
        transition: all 0.3s ease;
    }

    .custom-modal-overlay.is-visible .custom-modal-content { transform: translateY(0); }

    .custom-close-btn {
        position: absolute; top: 15px; right: 20px;
        background: none; border: none; font-size: 2rem;
        color: var(--body-text-color); cursor: pointer;
    }

    .modal-inner-header { text-align: center; margin-bottom: 2rem; }
    .modal-big-icon { font-size: 4rem; margin-bottom: 0.5rem; transform-origin: center; }

    /* Pop-in suave */
    .pop-in-soft {
        animation: popSoft 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    @keyframes popSoft {
        0% { transform: scale(0.5); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
    }

    .modal-inner-header h2 { font-family: 'Playfair Display', serif; font-size: 2.2rem; color: var(--heading-color); margin: 0; }
    .modal-inner-body { text-align: left; }
    #psych-modal-desc { color: var(--body-text-color); line-height: 1.7; font-size: 1.1rem; margin-bottom: 2rem; }
    .modal-inner-highlights { background: var(--bg-color); padding: 1.5rem; border-radius: 10px; }
    .modal-inner-highlights h4 { color: var(--heading-color); font-size: 1rem; margin: 0 0 15px 0; text-transform: uppercase; letter-spacing: 1px; }
    .modal-inner-highlights ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 10px; }
    .modal-inner-highlights li { font-size: 0.95rem; color: var(--body-text-color); display: flex; align-items: center; gap: 10px; }
    .modal-inner-highlights li span { color: #A2D9CE; font-weight: bold; }

    .modal-inner-close-action {
        width: 100%; background: #2C3E50; color: white; border: none;
        padding: 1rem; border-radius: 8px; font-weight: bold;
        font-size: 1rem; cursor: pointer; margin-top: 2rem; transition: background 0.3s;
    }
    .modal-inner-close-action:hover { background: #34495e; }

    @media (max-width: 600px) {
        .custom-modal-content { padding: 2rem; }
        .modal-inner-header h2 { font-size: 1.8rem; }
    }
</style>
