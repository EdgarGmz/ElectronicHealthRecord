---
// Kiosko/src/components/NursingSection.astro
const nursingTips = [
    {
        title: "Primeros Auxilios",
        description: "Maniobras básicas para actuar ante emergencias médicas.",
        icon: "🩹",
        details: "Maniobra de Heimlich, RCP básica, Curación de heridas, Control de hemorragias",
        fullInfo: "Los primeros auxilios son la ayuda inmediata que se presta a una persona enferma o herida. Conocer la técnica correcta puede salvar vidas en los primeros minutos críticos antes de que llegue la ayuda profesional."
    },
    {
        title: "Signos Vitales",
        description: "Monitoreo fundamental para detectar anomalías a tiempo.",
        icon: "❤️",
        details: "Presión arterial, Frecuencia cardíaca, Temperatura corporal, Oxigenación",
        fullInfo: "Los signos vitales reflejan funciones esenciales del cuerpo. Su monitoreo regular permite identificar problemas de salud ocultos y asegurar un funcionamiento óptimo del organismo."
    },
    {
        title: "Salud Sexual",
        description: "Información sobre métodos, prevención y planificación.",
        icon: "🧬",
        details: "Métodos anticonceptivos, Prevención ITS, Orientación reproductiva, Derechos sexuales",
        fullInfo: "La salud sexual es un estado de bienestar físico, mental y social. Requiere un enfoque positivo y respetuoso para experiencias seguras y placenteras."
    },
    {
        title: "Nutrición Saludable",
        description: "Aprende a elegir mejor tus alimentos para una vida sana.",
        icon: "🥗",
        details: "Plato del buen comer, Hidratación, Control de peso, Lectura de etiquetas",
        fullInfo: "Una nutrición adecuada es la base de la salud. Consumir una variedad de alimentos le da a tu cuerpo los nutrientes necesarios para prevenir enfermedades."
    },
    {
        title: "Higiene y Prevención",
        description: "Protocolos de limpieza y prevención de contagios.",
        icon: "🧼",
        details: "Lavado de manos, Uso de cubrebocas, Prevención de influenza, Higiene personal",
        fullInfo: "La higiene es la herramienta más efectiva para prevenir contagios. Pequeños hábitos diarios reducen drásticamente el riesgo de infecciones."
    },
    {
        title: "Salud Bucodental",
        description: "Cuidado preventivo para una sonrisa saludable y funcional.",
        icon: "🪥",
        details: "Técnica de Bass, Uso de hilo dental, Prevención de caries, Limpieza lingual",
        fullInfo: "La salud bucodental influye en todo el cuerpo. Una boca sana previene infecciones y mejora la calidad de vida y la autoestima."
    },
    {
        title: "Vacunación",
        description: "Información sobre esquemas y campañas de salud actuales.",
        icon: "💉",
        details: "Tétanos y Difteria, Refuerzos anuales, Cartilla de salud, Inmunización",
        fullInfo: "Las vacunas protegen a toda la comunidad. Estimulan tu sistema inmunitario para producir defensas contra enfermedades graves."
    }
];
---

<section id="nursing-section" class="page-section">
    <h2 class="section-title">Servicios de Enfermería</h2>
    
    <div class="options-container">
        {nursingTips.map((tip) => (
            <div class="option-card interactive-nursing-card" 
                 data-title={tip.title} 
                 data-icon={tip.icon} 
                 data-info={tip.fullInfo} 
                 data-list={tip.details}>
                <div class="card-icon animated-icon-soft">{tip.icon}</div>
                <h3>{tip.title}</h3>
                <p>{tip.description}</p>
                <span class="click-hint">Toca para ver más</span>
            </div>
        ))}
    </div>

    <!-- Modal Blanco Estable -->
    <div id="nursing-modal-fixed" class="custom-modal-overlay">
        <div class="custom-modal-content">
            <button class="custom-close-btn" id="close-nursing-modal">&times;</button>
            <div class="modal-inner-header">
                <div class="modal-big-icon pop-in-soft" id="nursing-modal-icon"></div>
                <h2 id="nursing-modal-title"></h2>
            </div>
            <div class="modal-inner-body">
                <p id="nursing-modal-desc"></p>
                <div class="modal-inner-highlights">
                    <h4>Puntos Clave</h4>
                    <ul id="nursing-modal-list"></ul>
                </div>
            </div>
            <button class="modal-inner-close-action" id="btn-nursing-close">Cerrar</button>
        </div>
    </div>
</section>

<script is:inline>
    (function() {
        const initNursingModal = () => {
            const modal = document.getElementById('nursing-modal-fixed');
            const cards = document.querySelectorAll('.interactive-nursing-card');
            const closeX = document.getElementById('close-nursing-modal');
            const closeBtn = document.getElementById('btn-nursing-close');

            if (!modal) return;

            const open = (data) => {
                const iconEl = document.getElementById('nursing-modal-icon');
                document.getElementById('nursing-modal-title').textContent = data.title;
                document.getElementById('nursing-modal-desc').textContent = data.info;
                iconEl.textContent = data.icon;
                
                const list = document.getElementById('nursing-modal-list');
                list.innerHTML = data.list.split(',').map(i => `<li><span>✓</span> ${i.trim()}</li>`).join('');

                modal.classList.add('is-visible');
                
                // Reiniciar animación pop-in sutil
                iconEl.style.animation = 'none';
                iconEl.offsetHeight;
                iconEl.style.animation = null;

                document.body.style.overflow = 'hidden';
            };

            const close = () => {
                modal.classList.remove('is-visible');
                document.body.style.overflow = '';
            };

            cards.forEach(card => {
                card.addEventListener('click', () => open(card.dataset));
            });

            closeX?.addEventListener('click', close);
            closeBtn?.addEventListener('click', close);
            modal.addEventListener('click', (e) => {
                if (e.target === modal) close();
            });
        };

        initNursingModal();
        document.addEventListener('astro:after-swap', initNursingModal);
    })();
</script>

<style>
    .page-section {
        width: 100%;
        max-width: 1200px;
        padding: 4rem 2rem;
        box-sizing: border-box;
        text-align: center;
        border-bottom: 1px solid var(--navbar-border);
        background-color: var(--bg-color);
    }

    .section-title {
        font-size: 2.5rem;
        margin-bottom: 3rem;
        color: var(--heading-color);
        font-family: 'Playfair Display', serif;
    }

    .options-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 3rem;
        text-align: left;
    }

    .option-card {
        padding: 2rem;
        transition: all 0.3s ease;
        background-color: var(--card-bg);
        border-radius: 12px;
        cursor: pointer;
        border: 1px solid var(--navbar-border);
        display: flex;
        flex-direction: column;
        position: relative;
    }

    .option-card:hover {
        background-color: rgba(162, 217, 206, 0.1);
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    }

    /* --- ANIMACIÓN SOFT DE EMOJIS (No sale de su órbita) --- */
    .animated-icon-soft {
        font-size: 2.5rem;
        margin-bottom: 1rem;
        display: inline-block;
        transform-origin: center;
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .option-card:hover .animated-icon-soft {
        transform: scale(1.15) rotate(5deg);
    }

    .option-card h3 { font-size: 1.5rem; margin-bottom: 0.5rem; color: var(--heading-color); font-family: 'Playfair Display', serif; }
    .option-card p { font-size: 1rem; line-height: 1.6; color: var(--body-text-color); margin-bottom: 1rem; }
    
    .click-hint { font-size: 0.8rem; color: #A2D9CE; font-weight: bold; text-transform: uppercase; margin-top: auto; }

    /* --- MODAL --- */
    .custom-modal-overlay {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.6);
        display: flex; align-items: center; justify-content: center;
        z-index: 9999; opacity: 0; visibility: hidden;
        transition: all 0.3s ease;
        backdrop-filter: blur(5px);
    }

    .custom-modal-overlay.is-visible { opacity: 1; visibility: visible; }

    .custom-modal-content {
        background: var(--card-bg);
        width: 90%; max-width: 500px;
        padding: 3rem; border-radius: 15px;
        position: relative; box-shadow: 0 25px 50px rgba(0,0,0,0.3);
        border: 1px solid var(--navbar-border);
        transform: translateY(20px);
        transition: all 0.3s ease;
    }

    .custom-modal-overlay.is-visible .custom-modal-content { transform: translateY(0); }

    .custom-close-btn {
        position: absolute; top: 15px; right: 20px;
        background: none; border: none; font-size: 2rem;
        color: var(--body-text-color); cursor: pointer;
    }

    .modal-inner-header { text-align: center; margin-bottom: 2rem; }
    .modal-big-icon { font-size: 4rem; margin-bottom: 0.5rem; transform-origin: center; }

    /* Pop-in suave */
    .pop-in-soft {
        animation: popSoft 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    @keyframes popSoft {
        0% { transform: scale(0.5); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
    }

    .modal-inner-header h2 { font-family: 'Playfair Display', serif; font-size: 2.2rem; color: var(--heading-color); margin: 0; }
    .modal-inner-body { text-align: left; }
    #nursing-modal-desc { color: var(--body-text-color); line-height: 1.7; font-size: 1.1rem; margin-bottom: 2rem; }
    .modal-inner-highlights { background: var(--bg-color); padding: 1.5rem; border-radius: 10px; }
    .modal-inner-highlights h4 { color: var(--heading-color); font-size: 1rem; margin: 0 0 15px 0; text-transform: uppercase; letter-spacing: 1px; }
    .modal-inner-highlights ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 10px; }
    .modal-inner-highlights li { font-size: 0.95rem; color: var(--body-text-color); display: flex; align-items: center; gap: 10px; }
    .modal-inner-highlights li span { color: #A2D9CE; font-weight: bold; }

    .modal-inner-close-action {
        width: 100%; background: #2C3E50; color: white; border: none;
        padding: 1rem; border-radius: 8px; font-weight: bold;
        font-size: 1rem; cursor: pointer; margin-top: 2rem; transition: background 0.3s;
    }
    .modal-inner-close-action:hover { background: #34495e; }

    @media (max-width: 600px) {
        .custom-modal-content { padding: 2rem; }
        .modal-inner-header h2 { font-size: 1.8rem; }
    }
</style>
