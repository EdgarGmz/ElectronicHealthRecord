---
// Kiosko/src/components/MentalHealthInfo.astro
const mentalHealthTips = [
    {
        title: "Habla de tus sentimientos",
        description: "Expresar lo que sientes te ayuda a procesar emociones y a sentirte acompañado.",
        icon: "💬"
    },
    {
        title: "Mantente activo",
        description: "El ejercicio regular libera endorfinas que mejoran tu estado de ánimo de forma natural.",
        icon: "🏃‍♂️"
    },
    {
        title: "Aliméntate bien",
        description: "Una dieta equilibrada nutre no solo tu cuerpo, sino también tu cerebro.",
        icon: "🍎"
    },
    {
        title: "Descansa adecuadamente",
        description: "El sueño reparador es esencial para la regulación emocional y la concentración.",
        icon: "😴"
    },
    {
        title: "Pide ayuda",
        description: "No tienes que cargar con todo solo. Buscar apoyo profesional es un signo de fortaleza.",
        icon: "🤝"
    },
    {
        title: "Practica el autocuidado",
        description: "Dedica tiempo a actividades que disfrutes y que te brinden paz mental.",
        icon: "✨"
    }
];

const healthCareTips = [
    {
        title: "Hidrátate constante",
        description: "Beber suficiente agua mantiene tus niveles de energía y mejora la concentración.",
        icon: "💧"
    },
    {
        title: "Chequeos regulares",
        description: "La prevención es clave. Visita a tu médico para revisiones periódicas.",
        icon: "🩺"
    },
    {
        title: "Cuida tu postura",
        description: "Mantén una espalda sana ajustando tu espacio de trabajo y estirando con frecuencia.",
        icon: "🧘‍♀️"
    },
    {
        title: "Límites de pantalla",
        description: "Reduce la fatiga visual tomando descansos de tus dispositivos cada 20 minutos.",
        icon: "📱"
    },
    {
        title: "Higiene personal",
        description: "Pequeños hábitos diarios protegen tu cuerpo de enfermedades e infecciones.",
        icon: "🧼"
    },
    {
        title: "Conecta con otros",
        description: "Las relaciones sociales positivas fortalecen tu sistema inmunológico y bienestar general.",
        icon: "👥"
