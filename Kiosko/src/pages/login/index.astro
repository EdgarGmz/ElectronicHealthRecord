---
import Layout from '../../layouts/Layout.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
---

<Layout title="Iniciar Sesión - Psicopedagogía">
    <header class="navbar">
        <div class="logo">Psicopedagogía</div>
        <nav>
            <a href="/" class="home-btn">Inicio</a>
            <a href="/signup" class="login-btn">Registrarse</a>
            <ThemeToggle />
        </nav>
    </header>

    <main class="login-page">
        <div class="login-container">
            <div class="form-header">
                <h1>Iniciar Sesión</h1>
                <p>Ingresa tus credenciales para agendar tu cita</p>
            </div>
            
            <form action="#" method="POST" class="login-form">
                <div class="input-group">
                    <label for="matricula">Matrícula</label>
                    <input type="text" id="matricula" name="matricula" placeholder="00000" required>
                </div>

                <div class="input-group">
                    <label for="password">Contraseña</label>
                    <input type="password" id="password" name="password" placeholder="••••••••" required>
                </div>

                <button type="submit" class="submit-button">Entrar</button>
            </form>
            
            <div class="form-footer">
                <p>¿Aún no tienes cuenta? <a href="/signup">Regístrate como alumno UTSC</a></p>
            </div>
        </div>
    </main>
</Layout>

<style>
    /* Navbar Styles */
    .navbar {
        position: sticky;
        top: 0;
        width: 100%;
        background-color: var(--navbar-bg);
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 30px;
        box-sizing: border-box;
        z-index: 1000;
        border-bottom: 1px solid var(--navbar-border);
        height: 70px;
    }

    .logo {
        color: var(--logo-color);
        font-size: 1.5rem;
        font-weight: bold;
        font-family: 'Playfair Display', serif;
    }

    .navbar nav {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .navbar nav a {
        color: var(--nav-link-color);
        text-decoration: none;
        font-weight: 600;
        transition: color 0.3s;
    }

    .navbar nav a:hover {
        color: var(--nav-link-hover);
    }

    .login-btn {
        background-color: #2C3E50;
        padding: 8px 20px;
        border-radius: 20px;
        color: white !important;
        transition: all 0.3s ease;
    }

    /* Login Page Styles */
    .login-page {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: calc(100vh - 70px);
        background-color: var(--bg-color);
        padding: 2rem 1rem;
        box-sizing: border-box;
    }

    .login-container {
        background-color: var(--card-bg);
        padding: 3rem;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
        width: 100%;
        max-width: 400px;
        animation: fadeIn 0.5s ease-out;
        border: 1px solid var(--navbar-border);
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .form-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .form-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        color: var(--heading-color);
        margin-bottom: 0.5rem;
    }

    .form-header p {
        color: var(--body-text-color);
        font-size: 0.9rem;
    }

    .input-group {
        margin-bottom: 1.5rem;
    }

    .input-group label {
        display: block;
        font-weight: 700;
        margin-bottom: 0.6rem;
        color: var(--heading-color);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .input-group input {
        width: 100%;
        padding: 0.9rem 1.2rem;
        border: 2px solid var(--navbar-border);
        border-radius: 12px;
        font-size: 1rem;
        box-sizing: border-box;
        transition: all 0.3s;
        background-color: var(--bg-color);
        color: var(--text-color);
    }

    .input-group input:focus {
        border-color: #A2D9CE;
        background-color: var(--card-bg);
        box-shadow: 0 0 0 4px rgba(162, 217, 206, 0.2);
        outline: none;
    }

    .submit-button {
        width: 100%;
        padding: 1.1rem;
        background-color: #2C3E50;
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 1rem;
    }

    .submit-button:hover {
        background-color: #34495e;
        transform: translateY(-2px);
    }

    .form-footer {
        margin-top: 2rem;
        text-align: center;
        border-top: 1px solid var(--navbar-border);
        padding-top: 1.5rem;
        font-size: 0.9rem;
        color: var(--body-text-color);
    }

    .form-footer a {
        color: #A2D9CE;
        text-decoration: none;
        font-weight: bold;
    }

    .form-footer a:hover {
        text-decoration: underline;
    }
</style>
