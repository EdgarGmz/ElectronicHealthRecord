---
import Layout from '../layouts/Layout.astro';
import Welcome from '../components/Welcome.astro';
import Roulette from '../components/Roulette.astro';
import Services from '../components/Services.astro';
import MentalHealthInfo from '../components/MentalHealthInfo.astro';
import Violentometro from '../components/Violentometro.astro';
---

<Layout title="EHR">

	<header class="navbar">

		<div class="logo">Psicopedagogía</div>

		<nav>

			<a href="/login" class="login-btn">Agendar cita</a>

		</nav>

	</header>



	<main>

		<Welcome />

		<Roulette />

		<Services />

		<MentalHealthInfo />

		<Violentometro />

	</main>

</Layout>



<style>

	:global(body) {

		font-family: 'Lato', sans-serif;

		background-color: #F7F7F7;

		color: #333;

		margin: 0;

	}



	:global(h1, h2, h3, h4, h5) {

		font-family: 'Playfair Display', serif;

	}



	.navbar {

		position: sticky;

		top: 0;

		width: 100%;

		background-color: #fff;

		display: flex;

		justify-content: space-between;

		align-items: center;

		padding: 0 30px;

		box-sizing: border-box;

		z-index: 1000;

		border-bottom: 1px solid #eee;

		height: 70px;

		transition: all 0.3s ease;

	}



	.logo {

		color: #333;

		font-size: 1.5rem;

		font-weight: bold;

		font-family: 'Playfair Display', serif;

	}



	.navbar nav a {

		color: #333;

		text-decoration: none;

		margin-left: 20px;

		font-weight: 600;

		transition: color 0.3s;

	}



	.navbar nav a:hover {

		color: #A2D9CE;

	}



	.login-btn {

		background-color: #2C3E50;

		padding: 8px 20px;

		border-radius: 20px;

		color: white !important;

		text-decoration: none;

		transition: all 0.3s ease;

	}



	.login-btn:hover {

		background-color: #34495e;

		transform: translateY(-2px);

	}



	main {

		display: flex;

		flex-direction: column;

		align-items: center;

		width: 100%;

	}



	/* Responsive Styles */

	@media (max-width: 768px) {

		.navbar {

			flex-direction: column;

			height: auto;

			padding: 15px;

		}

		.logo {

			margin-bottom: 10px;

		}

		.navbar nav {

			margin-top: 10px;

		}

	}

</style>
