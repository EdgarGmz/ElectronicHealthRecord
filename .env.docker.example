# Docker Environment Configuration
# Este archivo contiene las variables de entorno para el entorno Docker
# Para uso en producción, cambia todos los valores sensibles

# Database Configuration
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin1234
POSTGRES_DB=ehr_db

# JWT Configuration (¡CAMBIAR EN PRODUCCIÓN!)
JWT_SECRET=change-this-secret-key-in-production-use-strong-random-string
JWT_REFRESH_SECRET=change-this-refresh-secret-key-in-production-also-random

# Email Configuration (Configurar con credenciales reales)
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password

# Optional: Override default ports
# API_PORT=5000
# DB_PORT=5432
# REDIS_PORT=6379
