---
const emotions = [
	//Enojo #b63714
    { nombre: "Irritado", color: "#d19a7c" },
    { nombre: "Frustrado", color: "#d19a7c" },
    { nombre: "Furioso", color: "#d19a7c" },
	//Tristeza #453c4d
    { nombre: "Indiferente", color: "#7d708a" },
    { nombre: "Culpable", color: "#7d708a" },
    { nombre: "Lastimado", color: "#7d708a" },
	//Felicidad  #c0b4be
    { nombre: "Agradecido", color: "#ccc8c9" },
    { nombre: "Estusiasmado", color: "#ccc8c9" },
    { nombre: "Juguetón", color: "#ccc8c9" },
	//Sorpresa  #d8a13d
    { nombre: "Abrumado", color: "#d8cba8" },    
    { nombre: "Confundido", color: "#d8cba8" },   
    { nombre: "Impactado", color: "#d8cba8" },    
	//Repugnancia #d69f3b
    { nombre: "Amargado", color: "#d0d2c5" },    
    { nombre: "Decepcionado", color: "#d0d2c5" },      
    { nombre: "Resentido", color: "#d0d2c5" },
	//Amor #473e4f
    { nombre: "Afectuoso", color: "#8d7492" },
    { nombre: "Aceptado", color: "#8d7492" },
    { nombre: "Confiado", color: "#8d7492" },
	//Miedo  #babfc2
    { nombre: "Rechazado", color: "#d0d2c5" },
    { nombre: "Inseguro", color: "#d0d2c5" },
    { nombre: "Avergonzado", color: "#d0d2c5" },
];
---
<div id="rouletteSidebar" class="roulette-sidebar is-collapsed">
    <button id="rouletteToggleBtn" class="toggle-btn">
        <span>R</span><span>u</span><span>l</span><span>e</span><span>t</span><span>a</span>
    </button>
    <div id="roulette" class="roulette-content">
        <h2>Ruleta de Emociones</h2>
        <p>Gira la ruleta para explorar una emoción.</p>
        <div class="wheel-outer">
            <div class="wheel-container">
                <div class="wheel" id="wheel">
                    {emotions.map((emo, i) => (
                        <div class="segment" style={`--rotation: ${i * (360/emotions.length)}deg; --segment-color: ${emo.color};`}>
                            <span>{emo.nombre}</span>
                        </div>
                    ))}
                    <div class="center-circle"></div>
                </div>
            </div>
            <div class="pin"></div>
        </div>
        <button id="spinButton">Girar Ruleta</button>
        <div id="result" class="result-display"></div>
    </div>
</div>


<style>
    .roulette-sidebar {
        position: fixed;
        top: 50%;
        right: 0;
        transform: translateY(-50%);
        z-index: 1010;
        transition: transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
        display: flex;
        align-items: center;
    }

    .roulette-content {
        width: 450px;
        padding: 2rem;
        box-sizing: border-box;
        text-align: center;
        background: #fff;
        border-radius: 20px 0 0 20px;
        box-shadow: -5px 0 25px rgba(0,0,0,0.15);
        border: 1px solid #eee;
        border-right: none;
    }

    .toggle-btn {
        background-color: #333;
        color: white;
        border: none;
        writing-mode: vertical-rl;
        text-orientation: mixed;
        padding: 20px 10px;
        border-radius: 10px 0 0 10px;
        cursor: pointer;
        font-size: 1.2rem;
        font-weight: bold;
        letter-spacing: 2px;
        text-transform: uppercase;
        box-shadow: -2px 0 10px rgba(0,0,0,0.1);
    }
    
    .toggle-btn span {
        display: block;
        transform: rotate(180deg);
    }

    .roulette-sidebar.is-collapsed {
        transform: translateY(-50%) translateX(calc(100% - 50px)); /* Hide sidebar, but keep toggle visible */
    }

    /* --- Inner Roulette Styles --- */
    .roulette-content h2 {
        font-size: 2rem;
        margin-bottom: 1rem;
    }

    .roulette-content p {
        color: #555;
        margin-bottom: 2rem;
    }
    
    .wheel-outer {
        position: relative;
        margin: 10px auto;
    }

    .wheel-container {
        position: relative;
        width: 300px; /* smaller for sidebar */
        height: 300px;
        border-radius: 50%;
        border: 4px solid #e5e5e5;
        overflow: hidden;
        margin: 0 auto;
    }

    .wheel {
        width: 100%;
        height: 100%;
        position: relative;
        transition: transform 5s cubic-bezier(0.25, 0.1, 0.25, 1);
    }

    .segment {
        position: absolute;
        width: 50%;
        height: 47px;
        left: 50%;
        top: 50%;
        transform-origin: left center;
        margin-top: -23.5px;
        transform: rotate(var(--rotation));
        box-sizing: border-box;
    }

    .segment span {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        width: 100%;
        height: 100%;
        background-color: var(--segment-color);
        color: white;
        font-size: 0.7rem;
        font-weight: bold;
        clip-path: polygon(0 50%, 100% 0, 100% 100%);
        padding-right: 25px;
        font-family: 'Lato', sans-serif;
    }

    .center-circle {
        width: 100px;
        height: 100px;
        position: absolute;
        background: #fff;
        border: 4px solid #e5e5e5;
        border-radius: 50%;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 5;
    }

    .pin {
        position: absolute;
        bottom: -24px; 
        left: 50%;
        transform: translateX(-50%);
        width: 0; height: 0;
        border-left: 12px solid transparent;
        border-right: 12px solid transparent;
        border-bottom: 24px solid #ccc;
        z-index: 10;
    }

    button#spinButton {
        margin-top: 40px;
        padding: 10px 30px;
        font-size: 1rem;
        background-color: transparent;
        color: #333;
        border: 2px solid #333;
        border-radius: 50px;
        cursor: pointer;
        transition: all 0.3s;
    }

    button#spinButton:hover {
        background-color: #333;
        color: white;
    }

    .result-display {
        margin-top: 1.5rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: #333;
        min-height: 2rem;
    }
</style>

<script is:inline define:vars={{ emotions }}>
    document.addEventListener('DOMContentLoaded', () => {
        // Sidebar toggle logic
        const sidebar = document.getElementById('rouletteSidebar');
        const toggleBtn = document.getElementById('rouletteToggleBtn');

        if (sidebar && toggleBtn) {
            toggleBtn.addEventListener('click', () => {
                sidebar.classList.toggle('is-collapsed');
            });
        }

        // Roulette game logic
        const wheel = document.getElementById('wheel');
        const spinButton = document.getElementById('spinButton');
        const resultDisplay = document.getElementById('result');
        
        if (!wheel || !spinButton || !resultDisplay) {
            return;
        }

        let currentRotation = 0;

        spinButton.addEventListener('click', () => {
            const totalSegments = emotions.length;
            const randomSegment = Math.floor(Math.random() * totalSegments);
            const segmentAngle = 360 / totalSegments;
            const targetAngle = (randomSegment * segmentAngle) + (segmentAngle / 2);

            const extraDegrees = 360 * 5;
            const newRotation = currentRotation + extraDegrees + targetAngle;
            
            const finalAngle = (newRotation % 360);
            
            wheel.style.transform = `rotate(${newRotation}deg)`;
            currentRotation = newRotation;

            const winningSegmentIndex = Math.floor(((360 - finalAngle + (segmentAngle / 2)) % 360) / segmentAngle);
            const winningEmotion = emotions[winningSegmentIndex];

            resultDisplay.textContent = 'Girando...';
            setTimeout(() => {
                if(winningEmotion) {
                    resultDisplay.textContent = `Emoción: ${winningEmotion.nombre}`;
                }
            }, 5000);
        });
    });
</script>
